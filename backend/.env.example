# SpineGuard backend local environment
# 本文件只放本机开发配置。不要填写真实学生姓名、手机号或真实班级信息。

# Device upload token used by POST /api/v1/device/telemetry
SPINEGUARD_DEVICE_TOKEN=dev-token

# JWT signing secret. Change this locally before serious demo.
SPINEGUARD_SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default SQLite database. You can switch to MySQL later.
# DATABASE_URL=sqlite:///D:/桌面整合/2026春/竞赛/物联网/SG/backend/spineguard.db
# DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/spineguard

# LLM placeholder config. Fill these locally when you are ready to call a real model API.
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL=
