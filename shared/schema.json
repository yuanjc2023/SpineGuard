{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SpineGuard Telemetry V2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "device_id",
    "session_id",
    "seq",
    "timestamp_ms",
    "posture",
    "confidence",
    "pressure",
    "raw_pressure",
    "pressure_features",
    "posture_duration_s",
    "sitting_duration_s",
    "vibration_enabled",
    "warning_active",
    "reminder_count",
    "battery_level",
    "recognition_source",
    "model_version",
    "firmware_version"
  ],
  "properties": {
    "protocol_version": {
      "const": 2
    },
    "device_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp_ms": {
      "type": "integer",
      "minimum": 0
    },
    "posture": {
      "enum": [
        "empty",
        "normal",
        "left_lean",
        "right_lean",
        "front_lean",
        "back_lean",
        "unknown"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "pressure": {
      "type": "object",
      "required": [
        "left",
        "right",
        "front",
        "back",
        "center"
      ],
      "additionalProperties": false,
      "properties": {
        "left": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "right": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "front": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "back": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "center": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        }
      }
    },
    "device_name": {"type": "string", "maxLength": 64},
    "occupied": {"type": "boolean"},
    "ratio_valid": {"type": "boolean"},
    "raw_pressure": {
      "type": "object",
      "required": [
        "left",
        "right",
        "front",
        "back",
        "center"
      ],
      "additionalProperties": false,
      "properties": {
        "left": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4095
        },
        "right": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4095
        },
        "front": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4095
        },
        "back": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4095
        },
        "center": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4095
        }
      }
    },
    "pressure_features": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_pressure",
        "left_right_diff",
        "front_back_diff",
        "center_x",
        "center_y",
        "asymmetry_index"
      ],
      "properties": {
        "total_pressure": {
          "type": "integer",
          "minimum": 0,
          "maximum": 7500
        },
        "left_right_diff": {
          "type": "integer",
          "minimum": -1000,
          "maximum": 1000
        },
        "front_back_diff": {
          "type": "integer",
          "minimum": -1000,
          "maximum": 1000
        },
        "center_x": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "center_y": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "asymmetry_index": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "imu": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tilt_x",
        "tilt_y",
        "shake_level"
      ],
      "properties": {
        "tilt_x": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "tilt_y": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "shake_level": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "backrest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["online", "data_ready", "valid", "distance_mm", "range_status"],
      "properties": {
        "online": {"type": "boolean"},
        "data_ready": {"type": "boolean"},
        "valid": {"type": "boolean"},
        "distance_mm": {"type": ["number", "null"], "minimum": 0, "maximum": 4000},
        "range_status": {"type": "integer", "minimum": 0, "maximum": 255}
      }
    },
    "posture_duration_s": {
      "type": "integer",
      "minimum": 0
    },
    "sitting_duration_s": {
      "type": "integer",
      "minimum": 0
    },
    "vibration_enabled": {
      "type": "boolean"
    },
    "applied_config_version": {"type": "integer", "minimum": 0},
    "vibration_effective_enabled": {"type": "boolean"},
    "warning_active": {
      "type": "boolean"
    },
    "reminder_due": {"type": "boolean"},
    "reminder_suppressed": {"type": "boolean"},
    "vibration_active": {"type": "boolean"},
    "vibration_position": {"enum": ["left", "front", "right", "back", null]},
    "reminder_count": {
      "type": "integer",
      "minimum": 0
    },
    "reminder_cooldown_remaining_s": {"type": "integer", "minimum": 0},
    "reminder_config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "trigger_duration_s", "vibration_duration_s", "cooldown_s", "intensity_percent"],
      "properties": {
        "mode": {"enum": ["normal", "study", "do_not_disturb"]},
        "trigger_duration_s": {"type": "integer", "minimum": 5, "maximum": 3600},
        "vibration_duration_s": {"type": "integer", "minimum": 1, "maximum": 120},
        "cooldown_s": {"type": "integer", "minimum": 30, "maximum": 7200},
        "intensity_percent": {"type": "integer", "minimum": 0, "maximum": 100}
      }
    },
    "battery_level": {
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 100
    },
    "power_source": {"type": "string"},
    "wifi_rssi_dbm": {"type": ["integer", "null"], "minimum": -127, "maximum": 0},
    "sensor_status": {"type": "object"},
    "command_status": {"type": "object"},
    "device_credential_mode": {"enum": ["global_token", "per_device_secret"]},
    "recognition_source": {
      "enum": [
        "rule",
        "lightgbm",
        "neural_network",
        "mock"
      ]
    },
    "model_version": {
      "type": "string"
    },
    "firmware_version": {
      "type": "string"
    }
  }
}
