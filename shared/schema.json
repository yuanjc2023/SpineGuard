{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SpineGuard Telemetry V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "device_id",
    "session_id",
    "seq",
    "timestamp_ms",
    "posture",
    "confidence",
    "pressure",
    "posture_duration_s",
    "sitting_duration_s",
    "vibration_enabled",
    "warning_active",
    "recognition_source",
    "model_version",
    "firmware_version"
  ],
  "properties": {
    "protocol_version": {
      "const": 1
    },
    "device_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp_ms": {
      "type": "integer",
      "minimum": 0
    },
    "posture": {
      "enum": [
        "empty",
        "normal",
        "left_lean",
        "right_lean",
        "front_lean",
        "back_lean",
        "unknown"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "pressure": {
      "type": "object",
      "required": [
        "left",
        "right",
        "front",
        "back",
        "center"
      ],
      "properties": {
        "left": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "right": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "front": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "back": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "center": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        }
      }
    },
    "posture_duration_s": {
      "type": "integer",
      "minimum": 0
    },
    "sitting_duration_s": {
      "type": "integer",
      "minimum": 0
    },
    "vibration_enabled": {
      "type": "boolean"
    },
    "warning_active": {
      "type": "boolean"
    },
    "recognition_source": {
      "enum": [
        "rule",
        "neural_network",
        "mock"
      ]
    },
    "model_version": {
      "type": "string"
    },
    "firmware_version": {
      "type": "string"
    }
  }
}