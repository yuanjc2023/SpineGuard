<view class="page">
  <view class="card"><text>当前坐姿</text><text class="posture">{{posture}}</text><text>置信度{{confidence}}%</text></view>
  <view class="card">
    <text>5点压力</text>
    <view wx:for="{{['left','right','front','back','center']}}" wx:key="*this" class="row">
      <text>{{item}}</text><text>{{pressure[item]}}</text>
    </view>
  </view>
  <view class="card">
    <text>压力指数</text>
    <view class="row"><text>总压力</text><text>{{pressureFeatures.total_pressure}}</text></view>
    <view class="row"><text>左右差</text><text>{{pressureFeatures.left_right_diff}}</text></view>
    <view class="row"><text>前后差</text><text>{{pressureFeatures.front_back_diff}}</text></view>
    <view class="row"><text>不对称指数</text><text>{{pressureFeatures.asymmetry_index}}</text></view>
  </view>
  <view class="card">
    <view class="row"><text>提醒次数</text><text>{{reminderCount}}</text></view>
    <view class="row"><text>电量</text><text>{{batteryLevel}}%</text></view>
  </view>
  <view class="card">连接状态：{{connected?"正常":"断开"}}</view>
</view>
