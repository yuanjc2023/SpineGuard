page { background:#f4f7f5; color:#23352b; }
.container { width:100%; min-height:100vh; box-sizing:border-box; align-items:stretch; padding:22rpx 24rpx calc(48rpx + env(safe-area-inset-bottom)); }
.segment-shell { display:grid; grid-template-columns:minmax(0,1fr) minmax(0,1fr); width:100%; box-sizing:border-box; gap:8rpx; padding:7rpx; margin-bottom:22rpx; border:1rpx solid #dfe9e2; border-radius:23rpx; background:#eaf0ec; }
.segment-item { position:relative; display:flex; align-items:center; justify-content:center; min-width:0; gap:9rpx; height:76rpx; border-radius:17rpx; color:#77857c; font-size:25rpx; font-weight:700; transition:background-color .18s,color .18s,transform .12s; }
.segment-item.active { color:#1f7248; background:#fff; box-shadow:0 5rpx 16rpx rgba(47,84,61,.09); }
.segment-item:active { transform:scale(.985); }
.segment-badge { min-width:30rpx; height:30rpx; padding:0 7rpx; box-sizing:border-box; border-radius:99rpx; color:#fff; background:#e84b4b; font-size:17rpx; line-height:30rpx; text-align:center; }
.message { margin-bottom:18rpx; padding:18rpx 22rpx; border-radius:18rpx; font-size:21rpx; line-height:1.5; }
.message.error { color:#9e3b3b; background:#fff0f0; }.message.warning { color:#8b6b34; background:#fff8e8; }
.smart-generate-card { overflow:hidden; padding:29rpx; margin-bottom:25rpx; border-radius:30rpx; color:#fff; background:radial-gradient(circle at 92% 8%,rgba(143,255,180,.28),transparent 38%),linear-gradient(145deg,#145d43,#23965e); box-shadow:0 14rpx 36rpx rgba(27,111,71,.18); }
.smart-heading { display:flex; gap:19rpx; align-items:flex-start; }.smart-orb { display:flex; align-items:center; justify-content:center; width:88rpx; height:88rpx; flex-shrink:0; border:1rpx solid rgba(255,255,255,.36); border-radius:25rpx; background:rgba(255,255,255,.14); font-size:40rpx; }
.smart-copy { min-width:0; }.smart-eyebrow,.smart-title,.smart-desc { display:block; }.smart-eyebrow { color:#aef1c4; font-size:17rpx; letter-spacing:2rpx; }.smart-title { margin:6rpx 0; font-size:30rpx; font-weight:800; }.smart-desc { color:rgba(255,255,255,.77); font-size:20rpx; line-height:1.55; }
.smart-button { display:flex; align-items:center; justify-content:center; width:100%; height:76rpx; margin:23rpx 0 0; padding:0 24rpx; border:0; border-radius:20rpx; color:#165f3f; background:#e1ffea; font-size:24rpx; font-weight:750; line-height:1.2; box-shadow:inset 0 0 0 1rpx rgba(255,255,255,.42); transition:transform .12s,background-color .18s; }.smart-button:active { transform:scale(.99); background:#d2f8df; }.smart-button[disabled] { color:#4c8064; background:#d6eadc; box-shadow:none; }
.list-heading { display:flex; align-items:flex-end; justify-content:space-between; padding:3rpx 6rpx 14rpx; }.list-title,.list-sub { display:block; }.list-title { font-size:29rpx; font-weight:800; }.list-sub,.refresh-hint { margin-top:3rpx; color:#98a49d; font-size:19rpx; }
.loading-card,.empty-card { display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:250rpx; margin-bottom:22rpx; padding:30rpx; box-sizing:border-box; border-radius:25rpx; color:#87958d; background:#fff; font-size:21rpx; text-align:center; }
.loading-dot { width:22rpx; height:22rpx; margin-bottom:14rpx; border:5rpx solid #dceee2; border-top-color:#35ad68; border-radius:50%; animation:spin .8s linear infinite; }.empty-icon { font-size:50rpx; }.empty-title { margin:12rpx 0 5rpx; color:#34483c; font-size:27rpx; font-weight:700; }
.report-list,.system-list { overflow:hidden; border-radius:26rpx; background:#fff; box-shadow:0 8rpx 26rpx rgba(42,76,56,.06); }
.report-item { position:relative; display:grid; grid-template-columns:72rpx minmax(0,1fr) auto; gap:16rpx; align-items:center; min-height:110rpx; padding:23rpx 24rpx; border-bottom:1rpx solid #edf1ee; }
.report-item:last-child { border-bottom:0; }.smart-item { align-items:start; }.system-item.unread-item::before { content:''; position:absolute; left:0; top:18rpx; bottom:18rpx; width:7rpx; border-radius:0 99rpx 99rpx 0; background:#2ecc71; }.system-item.read-item { opacity:.68; }
.type-icon { display:flex; align-items:center; justify-content:center; width:72rpx; height:72rpx; border-radius:21rpx; color:#52715e; background:#edf5f0; font-size:23rpx; font-weight:800; }.type-smart { color:#226f47; background:linear-gradient(145deg,#dff8e8,#c9f0d7); }.type-daily { color:#3f786d; background:#e6f5f1; }.type-weekly { color:#726c45; background:#f7f3df; }.type-monthly { color:#6b5f87; background:#f0ebf8; }
.report-copy { min-width:0; }.report-type,.report-created,.report-range,.report-period { display:block; }.report-type { color:#263a2e; font-size:27rpx; font-weight:760; }.report-created { margin-top:4rpx; color:#66766c; font-size:21rpx; }.report-range,.report-period { margin-top:6rpx; color:#859289; font-size:19rpx; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.report-title-line,.report-meta { display:flex; align-items:center; }.report-title-line { gap:9rpx; }.report-meta { gap:8rpx; margin-top:9rpx; color:#98a49d; font-size:18rpx; }.meta-dot { color:#c6cdc9; }.generation-tag { color:#397e55; }.generation-tag.fallback { color:#9b7434; }
.new-dot { width:13rpx; height:13rpx; border-radius:50%; background:#e84b4b; }.chevron { align-self:center; color:#a7b1aa; font-size:44rpx; line-height:1; }
.system-summary-card { display:grid; grid-template-columns:64rpx 1fr auto; gap:16rpx; align-items:center; padding:24rpx; margin-bottom:19rpx; border:1rpx solid #dcece2; border-radius:25rpx; background:#fff; box-shadow:0 8rpx 24rpx rgba(40,77,55,.05); }.system-bell { display:flex; align-items:center; justify-content:center; width:64rpx; height:64rpx; border-radius:19rpx; background:#eaf8ef; font-size:29rpx; }.system-summary-copy { min-width:0; }.system-title,.system-desc,.unread-number,.unread-label { display:block; }.system-title { font-size:26rpx; font-weight:760; }.system-desc { margin-top:4rpx; color:#89968e; font-size:18rpx; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }.unread-box { min-width:75rpx; text-align:center; }.unread-number { color:#d74747; font-size:30rpx; font-weight:850; }.unread-label { color:#9b827f; font-size:17rpx; }
.filter-row { display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); width:100%; box-sizing:border-box; gap:6rpx; padding:6rpx; margin-bottom:20rpx; border:1rpx solid #e0e9e3; border-radius:20rpx; background:#eaf0ec; }.filter-chip { display:flex; align-items:center; justify-content:center; min-width:0; height:58rpx; padding:0; border:0; border-radius:15rpx; color:#7e8b83; background:transparent; font-size:21rpx; text-align:center; transition:background-color .18s,color .18s,transform .12s; }.filter-chip.active { color:#24764a; background:#fff; box-shadow:0 4rpx 13rpx rgba(47,84,61,.08); font-weight:700; }.filter-chip:active { transform:scale(.97); }
.system-group-title { padding:20rpx 24rpx 7rpx; color:#85938a; background:#fff; font-size:19rpx; font-weight:650; }.report-side { display:grid; grid-template-columns:auto auto; grid-template-areas:'risk arrow' 'read arrow'; align-items:center; gap:7rpx 10rpx; }.risk-tag { grid-area:risk; padding:5rpx 10rpx; border-radius:99rpx; color:#7b8981; background:#f1f4f2; font-size:17rpx; font-weight:650; }.risk-tag.low { color:#268653; background:#e8f8ee; }.risk-tag.medium { color:#a36c19; background:#fff6e3; }.risk-tag.high { color:#c43e3e; background:#fff0f0; }.risk-tag.reference { color:#537669; background:#eaf4f0; }.read-tag { grid-area:read; color:#9ba69f; font-size:17rpx; text-align:right; }.read-tag.unread { color:#d74848; font-weight:700; }.report-side .chevron { grid-area:arrow; }
@keyframes spin { to { transform:rotate(360deg); } }
