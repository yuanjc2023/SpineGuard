.container {
  display: block;
  width: 100%;
  box-sizing: border-box;
  min-height: 100vh;
  background: #f8f9fc;
  padding: 30rpx 30rpx 80rpx;
}

.device-hero,
.section {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 26rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(20, 38, 64, 0.05);
}

.wifi-config-section {
  padding-top: 22rpx;
  padding-bottom: 22rpx;
}

.wifi-config-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.wifi-config-copy {
  min-width: 0;
  flex: 1;
}

.wifi-connect-btn {
  flex-shrink: 0;
  width: 142rpx;
  height: 68rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 34rpx;
  background: #2ECC71;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 68rpx;
}

.wifi-connect-btn::after {
  border: 0;
}

.section-header,
.setting-row,
.action-row,
.check-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-main {
  display: grid;
  grid-template-columns: minmax(190rpx, .8fr) minmax(0, 1.4fr);
  align-items: center;
  gap: 20rpx;
}

.hero-identity,
.hero-side {
  min-width: 0;
}

.hero-side {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 14rpx;
}

.device-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.hero-label,
.meta-label,
.setting-desc,
.action-desc,
.section-tip,
.time-label {
  display: block;
  font-size: 24rpx;
  color: #718096;
  line-height: 1.5;
}

.device-name {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #1A202C;
  line-height: 1.2;
}

.device-nick {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #4A5568;
}

.device-config-sync {
  display: block;
  margin: 8rpx 0 14rpx;
  font-size: 22rpx;
  color: #2B7A78;
}

.pairing-status-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border: 1rpx solid #8AD8CE;
  background: #F0FFFB;
}

.pairing-status-card > view {
  min-width: 0;
  flex: 1;
}

.connect-badge {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  border-radius: 999rpx;
  padding: 7rpx 14rpx;
  font-size: 19rpx;
  line-height: 1.3;
}

.connect-badge.online {
  background: #E8F8EF;
  color: #229954;
}

.connect-badge.offline {
  background: #FFF5F5;
  color: #C53030;
}

.device-meta {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

.meta-item {
  background: #F7FAFC;
  border-radius: 14rpx;
  padding: 12rpx 8rpx;
  min-width: 0;
  text-align: center;
}

.meta-value {
  display: block;
  overflow: hidden;
  font-size: 23rpx;
  font-weight: 700;
  color: #1A202C;
  margin-bottom: 4rpx;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.meta-item .meta-label {
  font-size: 18rpx;
  white-space: nowrap;
}

.section-header {
  min-height: 64rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1A202C;
}

.section-tip {
  margin: 4rpx 0 18rpx;
}

.setting-row,
.action-row,
.check-row {
  min-height: 88rpx;
  border-top: 1rpx solid #EDF2F7;
}

.section-header + .setting-row,
.section-header + .check-row,
.section-tip + .setting-row,
.section .action-row:first-child {
  border-top: 0;
}

.setting-title,
.action-title {
  display: block;
  font-size: 29rpx;
  font-weight: 600;
  color: #2D3748;
  line-height: 1.45;
}

.setting-value,
.action-arrow {
  font-size: 27rpx;
  color: #718096;
  text-align: right;
}

.time-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 22rpx;
}

.time-box {
  background: #F7FAFC;
  border-radius: 18rpx;
  padding: 22rpx;
}

.time-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1A202C;
  margin-top: 8rpx;
}

.small-btn {
  margin: 0;
  min-width: 150rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 30rpx;
  background: #2ECC71;
  color: #ffffff;
  font-size: 24rpx;
  text-align:center;
}

.check-row {
  font-size: 28rpx;
  color: #4A5568;
}

.check-ok {
  color: #229954;
  font-weight: 700;
}

.danger-btn {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  font-size: 32rpx;
  margin-bottom: 24rpx;
}

.danger-btn {
  background: #FFF5F5;
  color: #C53030;
}
