.container {
  width: 100%;
  box-sizing: border-box;
  display: block;
  padding: 80rpx 40rpx;
  background-color: #f8f9fc;
  min-height: 100vh;
}
.logo-area {
  text-align: center;
  margin-bottom: 80rpx;
}
.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #2ECC71;
}
.slogan {
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
}
.input-group {
  margin-bottom: 40rpx;
}
.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}
.input {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  border: 1rpx solid #e0e0e0;
}
.login-btn {
  margin-top: 60rpx;
  background: #3498DB;
  color: white;
  border-radius: 48rpx;
  font-size: 36rpx;
  padding: 28rpx;
}
.demo-btn {
  margin-top: 24rpx;
  background: #fff;
  color: #2B6CB0;
  border: 1rpx solid #BEE3F8;
  border-radius: 48rpx;
  font-size: 30rpx;
  padding: 24rpx;
}
.tip {
  margin-top: 30rpx;
  text-align: center;
  font-size: 24rpx;
  color: #aaa;
}
.logo-image {
  width: 150rpx;
  height: 150rpx;
  display: block;
  margin: 0 auto;
}