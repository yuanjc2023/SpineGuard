page { background: #f3f7f4; color: #26382e; }
.exercise-page { padding: 24rpx 24rpx calc(50rpx + env(safe-area-inset-bottom)); }
.exercise-hero, .section-card { margin-bottom: 24rpx; border-radius: 30rpx; box-sizing: border-box; box-shadow: 0 10rpx 30rpx rgba(38,86,59,.08); }
.exercise-hero { padding: 38rpx 32rpx; color: #fff; background: radial-gradient(circle at 85% 18%,rgba(164,255,184,.25),transparent 32%),linear-gradient(145deg,#155d47,#218c5d); }
.eyebrow { display:block; font-size:20rpx; letter-spacing:3rpx; opacity:.72; }.hero-title { display:block; margin:12rpx 0; font-size:48rpx; font-weight:800; }.hero-desc { display:block; max-width:620rpx; font-size:23rpx; line-height:1.7; opacity:.88; }
.reason-list { display:flex; flex-wrap:wrap; gap:10rpx; margin-top:22rpx; }.reason-list text { padding:9rpx 14rpx; border-radius:99rpx; background:rgba(255,255,255,.13); font-size:20rpx; }.hero-button { margin:28rpx 0 0; border-radius:24rpx; color:#176747; background:#dcffe7; font-size:25rpx; }
.section-card { padding:28rpx; background:#fff; }.section-head { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:22rpx; }.section-title,.section-sub { display:block; }.section-title { font-size:31rpx; font-weight:750; }.section-sub { margin-top:5rpx; color:#8a988f; font-size:20rpx; }.rule-tag { padding:8rpx 14rpx; border-radius:99rpx; color:#3f8c59; background:#eaf7ed; font-size:19rpx; }
.metric-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:12rpx; }.metric { padding:20rpx; border-radius:18rpx; background:#f5f8f5; }.metric:first-child { grid-column:1/3; }.metric text { display:block; color:#8b978f; font-size:20rpx; }.metric-value { margin-top:7rpx; color:#26382e !important; font-size:30rpx !important; font-weight:700; }
.ai-box { margin-top:18rpx; padding:22rpx; border-radius:20rpx; background:#edf8f3; }.ai-title,.ai-text { display:block; }.ai-title { font-size:25rpx; font-weight:700; }.ai-text { margin:9rpx 0; color:#61736a; font-size:22rpx; line-height:1.65; }.ai-box button { margin:18rpx 0 0; border-radius:20rpx; color:#377b50; background:#fff; font-size:21rpx; }
.recommend-card { display:grid; grid-template-columns:120rpx 1fr 24rpx; gap:16rpx; align-items:center; padding:16rpx; border:2rpx solid transparent; border-radius:22rpx; background:#f6f9f6; margin-bottom:12rpx; }.recommend-card.active { border-color:#65be7d; background:#effaf2; }.recommend-score,.recommend-name,.recommend-target { display:block; }.recommend-score { color:#65a778; font-size:19rpx; }.recommend-name { margin:5rpx 0; font-size:28rpx; font-weight:750; }.recommend-target { color:#7d8b82; font-size:21rpx; }.chevron { color:#90a197; font-size:38rpx; }
.detail-visual { height:330rpx; display:flex; flex-direction:column; align-items:center; justify-content:center; border-radius:24rpx; background:radial-gradient(circle,#e1f8e8,transparent 67%); }.detail-visual>text { color:#718278; font-size:20rpx; }.detail-name { display:block; margin-top:20rpx; font-size:38rpx; font-weight:800; }.detail-summary { display:block; margin:7rpx 0 18rpx; color:#7b8980; font-size:22rpx; }.step { display:flex; align-items:flex-start; gap:15rpx; margin:13rpx 0; font-size:23rpx; line-height:1.55; }.step>text:first-child { flex-shrink:0; width:38rpx; height:38rpx; border-radius:50%; color:#fff; background:#51a96a; text-align:center; line-height:38rpx; }.step-copy { flex:1; }.caution { display:flex; flex-direction:column; gap:8rpx; margin:20rpx 0; padding:18rpx; border-left:6rpx solid #e7ae48; color:#7e6b44; background:#fff8e9; font-size:21rpx; line-height:1.55; }.caution-title { font-weight:700; }.start-button { border-radius:24rpx; color:#fff; background:#46a462; }
.category-scroll { white-space:nowrap; margin-bottom:20rpx; }.category-row { display:inline-flex; gap:12rpx; }.category { padding:12rpx 20rpx; border-radius:99rpx; color:#75847b; background:#eff3f0; font-size:21rpx; }.category.active { color:#fff; background:#4ba665; }.library-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:13rpx; }.library-card { min-width:0; padding:16rpx; border-radius:20rpx; background:#f6f9f6; }.library-category,.library-name,.library-target { display:block; }.library-category { margin-top:7rpx; color:#71a27f; font-size:18rpx; }.library-name { margin:5rpx 0; font-size:25rpx; font-weight:700; }.library-target { color:#859088; font-size:19rpx; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.mini-visual,.large-visual { position:relative; margin:auto; border-radius:18rpx; background:linear-gradient(145deg,#e8f8ed,#f4fbf6); }.mini-visual { width:112rpx; height:96rpx; }.large-visual { width:280rpx; height:250rpx; }.person-head,.person-body,.person-arm,.person-leg { position:absolute; display:block; background:#3eaa6a; }.person-head { left:45%; top:12%; border-radius:50%; }.mini-visual .person-head { width:22rpx; height:22rpx; }.large-visual .person-head { width:50rpx; height:50rpx; }.person-body { left:49%; top:33%; width:8rpx; height:38%; border-radius:9rpx; }.person-arm { left:50%; top:42%; width:34%; height:7rpx; transform:rotate(25deg); transform-origin:left; }.person-leg { left:50%; top:68%; width:35%; height:7rpx; transform:rotate(42deg); transform-origin:left; }.large-visual .person-body { width:12rpx; }.large-visual .person-arm,.large-visual .person-leg { height:11rpx; }.arm-two { transform:rotate(150deg); }.leg-two { transform:rotate(135deg); }.pose-side { animation:sideMove 2.3s ease-in-out infinite; }.pose-neck .person-head { animation:neckMove 2.4s ease-in-out infinite; }.pose-plank,.pose-cat,.pose-bridge,.pose-deadbug { transform:rotate(90deg); }.pose-cat .person-body { animation:catMove 2.2s ease-in-out infinite; }.pose-bridge .person-body { animation:bridgeMove 2.2s ease-in-out infinite alternate; }.pose-stand .person-arm { animation:raiseMove 2s ease-in-out infinite alternate; }
.plan-row { display:flex; gap:7rpx; }.plan-day { flex:1; min-width:0; padding:13rpx 3rpx; border:1rpx solid #dfe8e1; border-radius:15rpx; text-align:center; }.plan-day text { display:block; }.plan-day>text:first-child,.plan-date { color:#8b978f; font-size:16rpx; }.plan-status { margin:7rpx 0; font-weight:700; }.plan-day.guided { color:#3e9558; border-color:#6fc087; background:#eef9f1; }.recent-item { display:grid; grid-template-columns:100rpx 1fr; gap:8rpx 14rpx; padding:17rpx 0; border-bottom:1rpx solid #edf1ee; }.recent-item>text:first-child,.recent-time { color:#8b978f; font-size:18rpx; }.recent-name { font-size:22rpx; font-weight:700; }.recent-time { grid-column:2; }.recent-empty,.notice { padding:20rpx; color:#8a7560; text-align:center; }.notice { margin-bottom:20rpx; border-radius:18rpx; background:#fff2dc; }
.follow-card { overflow:hidden; }.video-source { flex-shrink:0; padding:8rpx 14rpx; border-radius:99rpx; color:#3f8c59; background:#eaf7ed; font-size:19rpx; }.follow-cover { position:relative; height:290rpx; overflow:hidden; border-radius:24rpx; background:linear-gradient(145deg,#174f3c,#2c9c61); }.follow-cover::before { content:''; position:absolute; inset:0; opacity:.16; background-image:linear-gradient(rgba(255,255,255,.45) 1rpx,transparent 1rpx),linear-gradient(90deg,rgba(255,255,255,.45) 1rpx,transparent 1rpx); background-size:42rpx 42rpx; }.follow-glow { position:absolute; width:310rpx; height:310rpx; right:-60rpx; top:-105rpx; border-radius:50%; background:rgba(154,248,176,.2); }.play-mark { position:absolute; left:50%; top:50%; display:flex; align-items:center; justify-content:center; width:92rpx; height:92rpx; border:3rpx solid rgba(255,255,255,.75); border-radius:50%; color:#185a3c; background:rgba(255,255,255,.9); transform:translate(-50%,-50%); box-shadow:0 10rpx 30rpx rgba(0,0,0,.18); }.play-mark text { margin-left:7rpx; font-size:34rpx; }.follow-badge { position:absolute; left:20rpx; bottom:18rpx; padding:9rpx 16rpx; border-radius:99rpx; color:#fff; background:rgba(7,42,29,.45); font-size:19rpx; }.follow-figure { position:absolute; left:72rpx; top:45rpx; width:130rpx; height:205rpx; opacity:.7; }.follow-head,.follow-body,.follow-arm,.follow-leg { position:absolute; background:#d6ffe2; }.follow-head { left:49rpx; top:0; width:42rpx; height:42rpx; border-radius:50%; }.follow-body { left:62rpx; top:39rpx; width:16rpx; height:90rpx; border-radius:12rpx; }.follow-arm,.follow-leg { left:68rpx; width:76rpx; height:12rpx; border-radius:12rpx; transform-origin:left center; }.follow-arm { top:62rpx; }.follow-arm.left { transform:rotate(-145deg); }.follow-arm.right { transform:rotate(-35deg); }.follow-leg { top:120rpx; }.follow-leg.left { transform:rotate(125deg); }.follow-leg.right { transform:rotate(55deg); }.follow-title,.follow-edition,.follow-note { display:block; }.follow-title { margin-top:22rpx; color:#26382e; font-size:30rpx; font-weight:750; }.follow-edition { margin-top:7rpx; color:#6d7e74; font-size:21rpx; }.follow-note { margin-top:16rpx; padding:17rpx 19rpx; border-radius:16rpx; color:#738078; background:#f5f8f5; font-size:20rpx; line-height:1.6; }.follow-button { margin:20rpx 0 0; border-radius:22rpx; color:#fff; background:#46a462; font-size:23rpx; }
.guide-overlay { position:fixed; inset:0; z-index:1000; padding:30rpx 28rpx calc(35rpx + env(safe-area-inset-bottom)); color:#fff; background:radial-gradient(circle at 50% 35%,rgba(77,212,128,.25),transparent 35%),linear-gradient(160deg,#09231d,#07151c); display:flex; flex-direction:column; align-items:center; }.guide-top { width:100%; display:flex; justify-content:space-between; align-items:center; }.guide-top button { width:auto; margin:0; padding:0 24rpx; color:#dcefe4; background:rgba(255,255,255,.09); font-size:20rpx; }.guide-visual { flex:1; min-height:350rpx; display:flex; align-items:center; }.guide-name { font-size:48rpx; font-weight:800; }.guide-step { min-height:70rpx; margin-top:14rpx; color:#b9d3c4; font-size:25rpx; text-align:center; }.guide-clock { margin:20rpx 0 12rpx; color:#6af09c; font-size:66rpx; font-weight:800; font-variant-numeric:tabular-nums; }.guide-track { width:80%; height:12rpx; overflow:hidden; border-radius:99rpx; background:rgba(255,255,255,.12); }.guide-track view { height:100%; background:linear-gradient(90deg,#4de8d0,#63ef8e); }.guide-safe { margin-top:18rpx; color:#9eb7a8; font-size:19rpx; text-align:center; }.guide-actions { width:100%; display:grid; grid-template-columns:1fr 1fr 1fr; gap:10rpx; margin-top:24rpx; }.guide-actions button { min-width:0; margin:0; padding:0; color:#d8ebe0; background:rgba(255,255,255,.09); font-size:21rpx; }.guide-actions .primary { color:#08311f; background:#69ec98; }.garden-feedback { position:fixed; inset:0; z-index:900; display:flex; flex-direction:column; align-items:center; justify-content:center; color:#fff; background:rgba(15,91,53,.9); }.garden-feedback>text:first-child { font-size:90rpx; }.feedback-title { margin:22rpx 0 10rpx; font-size:40rpx; font-weight:700; }.feedback-copy { font-size:21rpx; opacity:.8; }
@keyframes sideMove { 0%,100%{transform:rotate(-7deg)}50%{transform:rotate(9deg)} } @keyframes neckMove { 0%,100%{transform:rotate(-10deg)}50%{transform:rotate(10deg)} } @keyframes catMove { from{transform:scaleY(.82)}to{transform:scaleY(1.08)} } @keyframes bridgeMove { from{transform:rotate(-8deg)}to{transform:rotate(15deg)} } @keyframes raiseMove { from{transform:rotate(25deg)}to{transform:rotate(-70deg)} }
