page { background: #f3f7f5; }

.assistant-page {
  height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  padding: 22rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  color: #24352b;
  overflow: hidden;
}

.summary-card {
  position: relative;
  z-index: 3;
  flex-shrink: 0;
  padding: 28rpx 30rpx;
  border: 1rpx solid rgba(72, 166, 104, .14);
  border-radius: 30rpx;
  background: linear-gradient(140deg, rgba(255,255,255,.98), rgba(237,250,242,.98));
  box-shadow: 0 16rpx 40rpx rgba(39, 100, 63, .12);
}

.summary-head, .chat-title-row, .composer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-eyebrow, .summary-date, .summary-text, .chat-title, .chat-subtitle, .message-source, .safety-note {
  display: block;
}

.summary-eyebrow { font-size: 31rpx; font-weight: 700; color: #245a3a; }
.summary-date { margin-top: 5rpx; font-size: 21rpx; color: #8a9b90; }
.summary-text { margin-top: 19rpx; font-size: 26rpx; line-height: 1.58; color: #45584c; }

.summary-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 9rpx 15rpx;
  border-radius: 22rpx;
  background: #e8f7ee;
  color: #2f8f55;
  font-size: 20rpx;
}
.status-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: #35c878; }
.summary-badge.loading .status-dot { animation: pulse 1s ease-in-out infinite; }

.chat-panel {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  margin-top: 20rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background: rgba(255,255,255,.86);
  box-shadow: 0 10rpx 30rpx rgba(50, 80, 62, .06);
}

.chat-title-row { flex-shrink: 0; padding: 24rpx 28rpx 20rpx; border-bottom: 1rpx solid #edf2ee; }
.chat-title { font-size: 29rpx; font-weight: 700; color: #263a2e; }
.chat-subtitle { margin-top: 5rpx; font-size: 19rpx; color: #99a59d; }
.bot-avatar, .message-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(145deg, #54ce83, #2fa864);
  color: #fff;
  font-weight: 700;
}
.bot-avatar { width: 58rpx; height: 58rpx; font-size: 20rpx; }

.message-list { flex: 1; height: 0; min-height: 0; box-sizing: border-box; padding: 22rpx 24rpx; }
.message-row { display: flex; align-items: flex-start; gap: 13rpx; margin-bottom: 22rpx; }
.message-row.user { justify-content: flex-end; }
.message-avatar { flex-shrink: 0; width: 48rpx; height: 48rpx; font-size: 17rpx; }
.message-content { max-width: 78%; }
.message-row.user .message-content { display: flex; flex-direction: column; align-items: flex-end; }
.message-bubble { padding: 19rpx 22rpx; border-radius: 8rpx 24rpx 24rpx 24rpx; background: #f0f4f1; color: #435249; font-size: 25rpx; line-height: 1.55; }
.message-row.user .message-bubble { border-radius: 24rpx 8rpx 24rpx 24rpx; background: linear-gradient(135deg, #45bd72, #2ba45f); color: #fff; }
.message-source { margin-top: 6rpx; padding-left: 6rpx; color: #a0aaa3; font-size: 17rpx; }

.typing-bubble { display: flex; gap: 7rpx; padding: 20rpx 25rpx; border-radius: 8rpx 24rpx 24rpx 24rpx; background: #f0f4f1; }
.typing-bubble text { width: 8rpx; height: 8rpx; border-radius: 50%; background: #7f9486; animation: typing 1.1s infinite; }
.typing-bubble text:nth-child(2) { animation-delay: .15s; }
.typing-bubble text:nth-child(3) { animation-delay: .3s; }

.quick-list { flex-shrink: 0; width: 100%; padding: 2rpx 0 16rpx; white-space: nowrap; }
.quick-inner { display: inline-flex; gap: 12rpx; padding: 0 24rpx; }
.quick-chip { display: inline-block; width: auto; margin: 0; padding: 0 20rpx; height: 56rpx; line-height: 56rpx; border-radius: 28rpx; background: #edf8f1; color: #398b56; font-size: 21rpx; }

.composer { flex-shrink: 0; gap: 14rpx; padding: 16rpx 20rpx 10rpx; border-top: 1rpx solid #edf2ee; background: #fff; }
.chat-input { flex: 1; height: 72rpx; box-sizing: border-box; padding: 0 25rpx; border-radius: 36rpx; background: #f3f6f4; color: #324239; font-size: 25rpx; }
.send-button { flex-shrink: 0; width: 100rpx;text-align:center; height: 72rpx; line-height: 72rpx; margin: 0; padding: 0; border-radius: 36rpx; background: #35ad66; color: #fff; font-size: 24rpx; }
.send-button.disabled { background: #cbd5ce; color: #f5f7f5; }
.safety-note { flex-shrink: 0; padding: 0 20rpx 12rpx; text-align: center; color: #a1aaa4; font-size: 17rpx; background: #fff; }

@keyframes pulse { 0%,100% { opacity: .35; transform: scale(.8); } 50% { opacity: 1; transform: scale(1.2); } }
@keyframes typing { 0%,60%,100% { transform: translateY(0); opacity: .35; } 30% { transform: translateY(-5rpx); opacity: 1; } }
