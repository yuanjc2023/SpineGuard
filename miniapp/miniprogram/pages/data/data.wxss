page { background:#f3f7f4; color:#23352b; }
.container { display:block; width:100%; min-height:100vh; box-sizing:border-box; padding:22rpx 24rpx calc(150rpx + env(safe-area-inset-bottom)); background:radial-gradient(circle at 0 0,rgba(64,201,127,.08),transparent 24%),#f3f7f4; }
.sync-tip,.api-notice { display:flex; align-items:center; gap:12rpx; margin-bottom:18rpx; padding:16rpx 20rpx; border-radius:17rpx; font-size:20rpx; }
.sync-tip { color:#397253; background:#e8f7ed; }.api-notice { color:#8b5d20; background:#fff3d9; }
.loading-dot { width:17rpx; height:17rpx; border:4rpx solid #cfe7d7; border-top-color:#2fa66a; border-radius:50%; animation:spin .8s linear infinite; }

.score-card { overflow:hidden; padding:22rpx 24rpx; margin-bottom:18rpx; border-radius:27rpx; color:#fff; background:radial-gradient(circle at 94% 0,rgba(163,255,194,.28),transparent 34%),linear-gradient(145deg,#166143,#2fac68); box-shadow:0 12rpx 30rpx rgba(35,132,81,.15); }
.score-card.tone-watch { background:radial-gradient(circle at 94% 0,rgba(98, 188, 42, 0.336),transparent 34%),linear-gradient(145deg,#4a704b,#89a644); }
.score-card.tone-attention { background:radial-gradient(circle at 94% 0,rgba(195, 255, 190, 0.25),transparent 34%),linear-gradient(145deg,#4b7b44,#79c24c); }
.score-card.tone-waiting { background:linear-gradient(145deg,#587368,#789184); }
.card-top { display:flex; align-items:flex-start; justify-content:space-between; gap:16rpx; }.card-top.light { color:#fff; }
.eyebrow,.score-card-title,.card-title,.card-subtitle { display:block; }.eyebrow { color:rgba(255,255,255,.67); font-size:15rpx; letter-spacing:2rpx; }.score-card-title { margin-top:4rpx; font-size:27rpx; font-weight:800; }
.data-tag,.sample-tag { flex-shrink:0; padding:7rpx 12rpx; border-radius:99rpx; font-size:17rpx; }.data-tag { color:#e6ffed; background:rgba(255,255,255,.14); }.sample-tag { color:#5d7968; background:#edf4f0; }
.score-main { display:flex; align-items:center; gap:21rpx; margin-top:17rpx; }.score-ring { display:flex; align-items:center; justify-content:center; width:140rpx; height:140rpx; flex-shrink:0; border-radius:50%; transform:rotate(-90deg); }
.score-inner { display:flex; align-items:baseline; justify-content:center; width:112rpx; height:112rpx; border-radius:50%; color:#fff; background:#238258; transform:rotate(90deg); }.tone-watch .score-inner { background:#6f893f; }.tone-attention .score-inner { background:#7db228; }.tone-waiting .score-inner { background:#667f73; }
.score-number { align-self:center; font-size:50rpx; font-weight:850; line-height:1; }.score-total { align-self:center; margin-top:23rpx; color:rgba(255,255,255,.68); font-size:17rpx; }
.score-side { flex:1; min-width:0; }.score-copy { min-width:0; }.score-label,.score-change,.score-explain { display:block; }.score-label { font-size:27rpx; font-weight:800; }.score-change { margin-top:5rpx; color:#eaffef; font-size:20rpx; font-weight:650; }.score-explain { margin-top:7rpx; color:rgba(255,255,255,.67); font-size:16rpx; line-height:1.45; }
.score-facts { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:1rpx; margin-top:12rpx; overflow:hidden; border-radius:14rpx; background:rgba(255,255,255,.14); }.score-facts>view { min-width:0; padding:9rpx 4rpx; background:rgba(12,66,43,.11); text-align:center; }
.fact-value,.fact-label { display:block; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }.fact-value { font-size:17rpx; font-weight:750; }.fact-label { margin-top:2rpx; color:rgba(255,255,255,.65); font-size:13rpx; }
.score-composition { margin-top:16rpx; padding:16rpx 17rpx; border:1rpx solid rgba(255,255,255,.13); border-radius:18rpx; background:rgba(8,68,42,.13); }
.composition-heading { display:flex; align-items:center; justify-content:space-between; gap:16rpx; }.composition-title { font-size:21rpx; font-weight:750; }.composition-summary { color:rgba(255,255,255,.78); font-size:17rpx; }
.composition-bar { display:flex; width:100%; height:14rpx; margin-top:12rpx; overflow:hidden; border-radius:99rpx; background:rgba(255,255,255,.18); }.composition-bar.empty { background:rgba(255,255,255,.14); }.composition-segment { height:100%; min-width:0; }
.composition-legend { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:9rpx 14rpx; margin-top:13rpx; }.composition-item { display:flex; align-items:center; min-width:0; color:rgba(255,255,255,.75); font-size:16rpx; }.composition-dot { width:10rpx; height:10rpx; flex-shrink:0; margin-right:7rpx; border:2rpx solid rgba(255,255,255,.36); border-radius:50%; }.composition-percent { margin-left:auto; color:#fff; font-weight:700; }
.composition-insight { display:grid; grid-template-columns:auto minmax(0,1fr); gap:12rpx; align-items:center; margin-top:14rpx; padding-top:13rpx; border-top:1rpx solid rgba(255,255,255,.13); }.composition-observe { padding:6rpx 10rpx; border-radius:99rpx; color:#eaffef; background:rgba(255,255,255,.13); font-size:16rpx; font-weight:700; }.composition-advice { color:rgba(255,255,255,.72); font-size:16rpx; line-height:1.45; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }

.content-card { padding:26rpx; margin-bottom:22rpx; border:1rpx solid #e5ece7; border-radius:27rpx; background:#fff; box-shadow:0 9rpx 28rpx rgba(44,78,57,.055); }
.card-title { color:#263a2e; font-size:28rpx; font-weight:800; }.card-subtitle { margin-top:5rpx; color:#89968e; font-size:18rpx; line-height:1.45; }
.status-pill { max-width:210rpx; padding:7rpx 12rpx; border-radius:99rpx; color:#317950; background:#e8f7ed; font-size:17rpx; text-align:center; }.status-pill.watch { color:#9b6a21; background:#fff5df; }.status-pill.attention { color:#b14c40; background:#fff0ec; }.status-pill.waiting { color:#718079; background:#edf1ef; }

.timeline-track { position:relative; display:grid; grid-template-columns:repeat(3,1fr); gap:6rpx; margin-top:28rpx; }.timeline-track::before { content:''; position:absolute; left:16%; right:16%; top:58rpx; height:4rpx; border-radius:99rpx; background:#dfe9e3; }
.time-segment { position:relative; z-index:1; display:flex; flex-direction:column; align-items:center; min-width:0; text-align:center; }.time-range { color:#95a198; font-size:16rpx; }.timeline-node { display:flex; align-items:center; justify-content:center; width:64rpx; height:64rpx; margin:10rpx 0 9rpx; border:6rpx solid #f6faf7; border-radius:50%; background:#e8f6ed; font-size:28rpx; box-shadow:0 0 0 2rpx #cce5d5; }
.time-label { color:#68776e; font-size:17rpx; }.time-title { margin-top:5rpx; color:#2d4235; font-size:20rpx; font-weight:750; }.time-detail { margin-top:3rpx; color:#98a39c; font-size:15rpx; }

.balance-card { border-color:#dce9e1; box-shadow:0 12rpx 30rpx rgba(43,87,59,.07); }
.chart-toolbar { display:flex; align-items:center; justify-content:space-between; gap:16rpx; margin-top:20rpx; padding:8rpx 10rpx 8rpx 16rpx; border:1rpx solid #e4ece7; border-radius:18rpx; background:#f4f8f5; }.toolbar-label { flex-shrink:0; color:#829087; font-size:17rpx; }.period-tabs { display:grid; grid-template-columns:repeat(4,64rpx); gap:5rpx; padding:5rpx; border-radius:14rpx; background:#e4ece7; }.period-tab { display:flex; align-items:center; justify-content:center; height:46rpx; border-radius:10rpx; color:#738178; font-size:19rpx; font-weight:700; transition:background-color .18s,color .18s,transform .12s; }.period-tab.active { color:#1f7548; background:#fff; box-shadow:0 4rpx 12rpx rgba(47,84,61,.10); }.period-tab:active { transform:scale(.96); }

.chart-shell { position:relative; margin-top:12rpx; padding:38rpx 10rpx 4rpx; border:1rpx solid #e9efeb; border-radius:21rpx; background:#f8faf9; }.good-zone-label { position:absolute; top:12rpx; left:18rpx; display:flex; align-items:center; gap:7rpx; color:#629075; font-size:16rpx; }.zone-dot { width:10rpx; height:10rpx; border-radius:50%; background:#42c98a; }.line-chart { width:100%; height:380rpx; }
.balance-summary { display:grid; grid-template-columns:170rpx 1fr; gap:22rpx; align-items:center; margin-top:18rpx; padding:18rpx 20rpx; border-radius:19rpx; background:#f4f8f5; }.summary-label { display:block; color:#87948c; font-size:17rpx; }.summary-value-line { display:flex; align-items:center; gap:10rpx; margin-top:3rpx; }.summary-value { color:#263a2e; font-size:36rpx; font-weight:850; }.direction { color:#7e8c84; font-size:28rpx; }.direction.down { color:#2cab69; }.direction.up { color:#ef7a60; }
.balance-compare text { display:block; }.balance-compare text:first-child { color:#3d7152; font-size:21rpx; font-weight:700; }.balance-compare text:last-child { margin-top:6rpx; color:#8a978f; font-size:17rpx; line-height:1.45; }

.advice-card { display:grid; grid-template-columns:70rpx 1fr; gap:18rpx; padding:27rpx; margin-bottom:21rpx; border-radius:28rpx; color:#fff; background:radial-gradient(circle at 95% 5%,rgba(74,232,179,.25),transparent 38%),linear-gradient(145deg,#153f34,#176b4a); box-shadow:0 13rpx 34rpx rgba(24,93,64,.16); }.advice-icon { display:flex; align-items:center; justify-content:center; width:70rpx; height:70rpx; border:1rpx solid rgba(255,255,255,.2); border-radius:20rpx; background:rgba(255,255,255,.1); font-size:30rpx; }.advice-copy { min-width:0; }.advice-heading { display:flex; align-items:center; justify-content:space-between; gap:12rpx; }.advice-title { font-size:28rpx; font-weight:800; }.advice-source { padding:5rpx 10rpx; border-radius:99rpx; color:#baf3d0; background:rgba(255,255,255,.1); font-size:15rpx; }
.advice-eyebrow,.advice-focus,.advice-text { display:block; }.advice-eyebrow { margin-top:15rpx; color:#91d4ad; font-size:17rpx; }.advice-focus { margin-top:4rpx; font-size:24rpx; font-weight:750; }.advice-text { margin-top:9rpx; color:rgba(255,255,255,.74); font-size:20rpx; line-height:1.65; }.assistant-button { display:flex; align-items:center; justify-content:center; width:100%; height:66rpx; margin:20rpx 0 0; padding:0 20rpx; border:0; border-radius:18rpx; color:#176344; background:#dff9e8; font-size:21rpx; font-weight:700; line-height:1; }.assistant-button text { margin-left:8rpx; font-size:30rpx; }.assistant-button:active { transform:scale(.99); background:#cef2da; }
.data-note { display:block; padding:0 16rpx; color:#9aa69f; font-size:17rpx; line-height:1.55; text-align:center; }
@keyframes spin { to { transform:rotate(360deg); } }
