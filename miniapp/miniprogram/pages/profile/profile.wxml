<!--pages/profile/profile.wxml-->
<view class="container">
  <view class="user-info">
    <view class="avatar">
      <text>家</text>
    </view>
    <text class="nickname">{{userInfo.nickName}}</text>
    <text class="device-status">已绑定设备: {{deviceCode}}</text>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goToDeviceManage">
      <text>📱 设备管理</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToChildInfo">
      <text>👧 学生信息</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToAISports">
      <text>🤖 坐姿 AI 助手</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToExerciseGuide">
      <text>🧘 智能护脊训练</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToReportCenter">
      <view class="menu-label"><text>📄 报告中心</text><text class="report-badge" wx:if="{{unreadReportCount}}">{{unreadReportText}}</text></view>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToHelp">
      <text>❓ 帮助与反馈</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToAbout">
      <text>ℹ️ 关于我们</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item danger" bindtap="unbindDevice">
      <text>{{accountActionText}}</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
