/* pages/profile/profile.wxss */
.container {
  width: 100%;
  box-sizing: border-box;
  display: block;
  background-color: #f8f9fc;
  min-height: 100vh;
  padding: 30rpx;
}
.user-info {
  background: white;
  border-radius: 32rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
}
.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #E8F8EF;
  color: #2ECC71;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  margin-left: auto;
  margin-right: auto;
}
.nickname {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}
.device-status {
  font-size: 28rpx;
  color: #666;
}
.menu-list {
  background: white;
  border-radius: 32rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  font-size: 32rpx;
}
.menu-item:last-child {
  border-bottom: none;
}
.arrow {
  color: #ccc;
}
.menu-label {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.report-badge {
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  border-radius: 99rpx;
  color: #fff;
  background: #E53E3E;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 34rpx;
  text-align: center;
}
.danger {
  color: #E53E3E;
}
