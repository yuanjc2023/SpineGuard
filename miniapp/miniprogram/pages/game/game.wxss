page { background: #f3f7f1; }

.garden-page {
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx 24rpx calc(130rpx + env(safe-area-inset-bottom));
  color: #2e4a38;
}

.hero-card, .section-card, .resource-card, .energy-card {
  border-radius: 30rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(44, 92, 57, 0.08);
}

.hero-card {
  position: relative;
  overflow: hidden;
  padding: 30rpx;
  color: #fff;
  background: linear-gradient(145deg, #5bb96b 0%, #27965b 100%);
  transition: background .3s ease;
}

.hero-card.left-lean, .hero-card.right-lean { background: linear-gradient(145deg, #92d480, #ee184e60); }
.hero-card.front-lean { background: linear-gradient(145deg, #e0ae5fa1, #8ab643); }
.hero-card.back-lean { background: linear-gradient(145deg, #97eae3, #5c9f8ccb); }
.hero-card.empty { background: linear-gradient(145deg, #e5e3df, #9b7e60); }
.hero-card.unknown { background: linear-gradient(145deg, #7a9487, #9aa59f); }
.hero-card.offline { background: linear-gradient(145deg, #7f8884, #58887d); filter: saturate(.45); }

.hero-top, .growth-row, .section-header, .energy-card, .task-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.eyebrow { display: block; font-size: 23rpx; opacity: .8; margin-bottom: 8rpx; }
.stage-title { font-size: 39rpx; font-weight: 700; }
.stage-badge { max-width: 300rpx; padding: 12rpx 18rpx; border-radius: 24rpx; background: rgba(255,255,255,.18); font-size: 21rpx; line-height: 1.45; text-align: right; }

.tree-scene { height: 300rpx; position: relative; display: flex; align-items: center; justify-content: center; }
.weather-icon { position: absolute; right: 32rpx; top: 32rpx; font-size: 48rpx; animation: float 2.5s ease-in-out infinite; }
.tree-visual { position: relative; width: 250rpx; height: 260rpx; transform-origin: 50% 100%; transition: transform .35s ease, filter .35s ease; }
.left-lean .tree-visual { transform: rotate(-9deg); }
.right-lean .tree-visual { transform: rotate(9deg); }
.front-lean .tree-visual { transform: scaleY(.86); filter: saturate(.7); }
.back-lean .tree-visual { transform: rotate(5deg); animation: sway .8s ease-in-out infinite alternate; }
.unknown .tree-visual { opacity: .72; filter: saturate(.55); }
.empty .tree-visual { animation-duration: 5s; filter: saturate(.7); }
.severity-mild .tree-visual { filter: saturate(.88); }
.severity-warning .tree-visual { transform: rotate(-13deg) scaleY(.92); filter: saturate(.72); }
.severity-severe .tree-visual { transform: rotate(-18deg) scaleY(.78); filter: saturate(.42); }
.recovery-needed .tree-visual { filter: saturate(.55); opacity: .82; }
.tree-crown { position: absolute; z-index: 2; border-radius: 50%; background: #8ddd71; box-shadow: inset -12rpx -12rpx 0 rgba(31,126,61,.18); }
.crown-main { width: 170rpx; height: 150rpx; left: 42rpx; top: 45rpx; }
.crown-small { width: 112rpx; height: 105rpx; left: 4rpx; top: 92rpx; }
.crown-side { width: 120rpx; height: 112rpx; right: 0; top: 96rpx; }
.tree-trunk { position: absolute; left: 106rpx; bottom: 22rpx; width: 42rpx; height: 115rpx; border-radius: 16rpx 16rpx 8rpx 8rpx; background: #895c3d; z-index: 1; }
.tree-ground { position: absolute; left: 20rpx; bottom: 9rpx; width: 210rpx; height: 35rpx; border-radius: 50%; background: rgba(22,91,48,.35); }
.seed-shell, .sprout-stem, .sprout-leaf, .tree-flower, .tree-fruit { position: absolute; display: none; }
.stage-seed .tree-crown, .stage-seed .tree-trunk, .stage-sprout .tree-crown, .stage-sprout .tree-trunk { display: none; }
.stage-seed .seed-shell { display: block; left: 91rpx; bottom: 35rpx; width: 70rpx; height: 52rpx; border-radius: 55% 45% 58% 42%; background: #7a5135; box-shadow: inset -12rpx -8rpx rgba(70,35,20,.25); transform: rotate(-12deg); }
.stage-sprout .sprout-stem { display: block; left: 121rpx; bottom: 38rpx; width: 12rpx; height: 100rpx; border-radius: 10rpx; background: #4d8d43; }
.stage-sprout .sprout-leaf { display: block; bottom: 100rpx; width: 58rpx; height: 32rpx; border-radius: 70% 20% 70% 20%; background: #9be17e; }
.stage-sprout .leaf-left { left: 66rpx; transform: rotate(22deg); }
.stage-sprout .leaf-right { right: 66rpx; transform: scaleX(-1) rotate(22deg); }
.stage-sapling .tree-trunk { width: 26rpx; height: 95rpx; left: 113rpx; }
.stage-sapling .crown-main { width: 125rpx; height: 112rpx; left: 63rpx; top: 72rpx; }
.stage-sapling .crown-small { width: 74rpx; height: 70rpx; left: 35rpx; top: 112rpx; }
.stage-sapling .crown-side { width: 76rpx; height: 72rpx; right: 32rpx; top: 112rpx; }
.stage-tree .tree-trunk, .stage-flower .tree-trunk, .stage-fruit .tree-trunk { height: 130rpx; width: 46rpx; left: 103rpx; }
.stage-tree .tree-crown, .stage-flower .tree-crown, .stage-fruit .tree-crown { transform: scale(1.08); }
.stage-flower .tree-flower, .stage-fruit .tree-flower { display: block; z-index: 4; color: #ffd6e7; font-size: 34rpx; text-shadow: 0 2rpx 5rpx rgba(120,35,70,.25); }
.flower-one { left: 48rpx; top: 86rpx; }.flower-two { left: 110rpx; top: 48rpx; }.flower-three { right: 37rpx; top: 106rpx; }
.stage-fruit .tree-flower { display: none; }
.stage-fruit .tree-fruit { display: block; z-index: 4; color: #f2604b; font-size: 34rpx; text-shadow: inset 0 -3rpx #b43d31; }
.fruit-one { left: 53rpx; top: 112rpx; }.fruit-two { left: 121rpx; top: 78rpx; }.fruit-three { right: 42rpx; top: 127rpx; }

.status-box { text-align: center; padding: 18rpx 20rpx; margin-bottom: 24rpx; border-radius: 20rpx; background: rgba(255,255,255,.15); }
.status-name { display: block; font-size: 27rpx; font-weight: 700; margin-bottom: 7rpx; }
.status-message { font-size: 24rpx; opacity: .9; }
.growth-row { font-size: 23rpx; margin-bottom: 10rpx; }
.progress-track { height: 14rpx; border-radius: 8rpx; background: rgba(255,255,255,.25); overflow: hidden; }
.progress-fill { height: 100%; border-radius: 8rpx; background: #ffe789; transition: width .35s ease; }
.next-stage { display: block; margin-top: 11rpx; font-size: 22rpx; opacity: .85; text-align: right; }
.rule-version { display: block; margin-top: 10rpx; font-size: 18rpx; opacity: .72; text-align: right; }

.resource-card { display: flex; align-items: center; justify-content: space-around; padding: 25rpx 18rpx; background: #fff; }
.resource-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.resource-icon { font-size: 39rpx; }
.resource-value { margin: 4rpx 0; font-size: 34rpx; font-weight: 700; color: #26352b; }
.resource-label { color: #849086; font-size: 22rpx; }
.resource-divider { width: 1rpx; height: 70rpx; background: #e8eee8; }

.section-card { padding: 28rpx; background: #fff; }
.section-header { margin-bottom: 24rpx; }
.section-title, .section-subtitle { display: block; }
.section-title { font-size: 31rpx; font-weight: 700; color: #26352b; }
.section-subtitle { margin-top: 6rpx; color: #93a098; font-size: 21rpx; }
.task-date { padding: 8rpx 16rpx; background: #eef8ef; color: #469158; border-radius: 18rpx; font-size: 21rpx; }

.action-grid { width: 100%; display: grid; grid-template-columns: repeat(2, 1fr); gap: 12rpx; box-sizing: border-box; }
.action-button { width: 100%; height: 142rpx; min-width: 0; padding: 12rpx 4rpx; box-sizing: border-box; overflow: hidden; border-radius: 20rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; line-height: 1; transition: transform .15s ease, opacity .15s ease; }
.action-button-active { transform: scale(.97); opacity: .82; }
.action-button.disabled { opacity: .42; pointer-events: none; }
.action-icon-badge { width: 52rpx; height: 52rpx; margin: 0 auto 7rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,.62); }
.action-icon { display: block; text-align: center; font-size: 31rpx; line-height: 36rpx; }
.action-name { display: block; width: 100%; text-align: center; font-size: 23rpx; line-height: 28rpx; font-weight: 650; }
.action-meta { display: block; width: 100%; margin-top: 6rpx; overflow: hidden; text-align: center; text-overflow: clip; font-size: 15rpx; line-height: 20rpx; font-weight: 500; opacity: .72; white-space: nowrap; }
.sun-button { background: #fff5d9; color: #9a7117; }
.water-button { background: #e5f5ff; color: #397fa8; }
.food-button { background: #e9f8e8; color: #3d824c; }
.recover-button { background: #f0efe8; color: #61705f; }

.task-item { display: grid; grid-template-columns: 2rpx minmax(0, 1fr) 132rpx 158rpx; align-items: center; padding: 6rpx 0; border-bottom: 1rpx solid #edf1ed; column-gap: 12rpx; }
.task-check { flex-shrink: 0; width: 2rpx; height: 36rpx; line-height: 36rpx; text-align: center; border-radius: 50%; color: #fff; background: #d9e1da; font-size: 22rpx; }
.task-check.checked { background: #53ad67; }
.task-content { min-width: 0; }
.task-title { display: block; color: #2a352d; font-size: 24rpx; line-height: 29rpx; }
.task-meta { display: flex; min-width: 0; flex-direction: column; align-items: center; justify-content: center; gap: 3rpx; color: #95a098; font-size: 19rpx; line-height: 24rpx; }
.task-progress, .task-reward { display: block; max-width: 100%; white-space: nowrap; }
.task-reward { color: #7e8c82; }
.claim-button { width: 158rpx; height: 54rpx; margin: 0; padding: 0; border-radius: 27rpx; background: #4ca861; color: #fff; text-align: center; font-size: 21rpx; line-height: 54rpx; box-sizing: border-box; }
.claim-button.claimed { background: #e8ede9; color: #98a29a; }

.exercise-button { margin-top: 24rpx; border-radius: 24rpx; background: #eef8ef; color: #3f8d52; font-size: 25rpx; }

.energy-card { padding: 25rpx; background: linear-gradient(135deg, #fff8d8, #edf9e8); gap: 18rpx; }
.energy-balls { position: relative; width: 102rpx; flex-shrink: 0; }
.energy-balls text { display: inline-block; font-size: 35rpx; margin: -3rpx; }
.energy-content { flex: 1; min-width: 0; }
.energy-title, .energy-desc { display: block; }
.energy-title { font-size: 26rpx; font-weight: 700; color: #486241; }
.energy-desc { margin-top: 7rpx; color: #889582; font-size: 20rpx; }
.energy-button { flex-shrink: 0; margin: 0; padding: 0 22rpx; height: 62rpx; line-height: 62rpx; border-radius: 31rpx; background: #f0b83f; color: #fff; font-size: 22rpx; }
.energy-button.disabled { background: #ccd4c8; }

.posture-options { display: flex; flex-wrap: wrap; gap: 14rpx; }
.posture-chip { padding: 13rpx 20rpx; border-radius: 24rpx; background: #f1f4f1; color: #647067; font-size: 22rpx; }
.posture-chip.active { background: #4ca861; color: #fff; }
.study-button { margin-top: 24rpx; background: #4ca861; color: #fff; font-size: 24rpx; border-radius: 24rpx; }
.reset-button { margin-top: 24rpx; background: transparent; color: #879087; font-size: 22rpx; border: 1rpx solid #e4e9e4; border-radius: 24rpx; }
.api-notice { margin-bottom: 20rpx; padding: 20rpx 24rpx; border-radius: 20rpx; color: #8b5d20; background: #fff3d9; font-size: 22rpx; }
.focus-summary { display: flex; flex-direction: column; gap: 10rpx; color: #657169; font-size: 22rpx; line-height: 1.5; }

.focus-targets {
  width:100%;
  margin-top:20rpx;
  display:grid;
  grid-template-columns:repeat(2,300rpx);
  justify-content:center;
  column-gap:30rpx;
  row-gap:18rpx;
}

.focus-target {
  width:300rpx;
  height:62rpx;
  line-height:62rpx;
  margin:0;
  padding:0;
  border-radius:22rpx;
  text-align:center;
  background:#4ca861;
  color:white;
  font-size:26rpx;
  box-sizing:border-box;
}
.focus-enter-button { grid-column: 1 / 3; width: 100%; margin-top: 0; }
.training-entry { display:grid; grid-template-columns:78rpx 1fr 30rpx; gap:18rpx; align-items:center; background:linear-gradient(135deg,#effaf2,#e8f7f4); }
.training-mark { width:78rpx; height:78rpx; border-radius:25rpx; color:#fff; background:linear-gradient(145deg,#4eb672,#2f9160); display:flex; align-items:center; justify-content:center; font-size:34rpx; font-weight:800; box-shadow:0 8rpx 18rpx rgba(52,145,88,.2); }
.training-copy { min-width:0; }.training-boundary { display:block; margin-top:10rpx; color:#5d9470; font-size:19rpx; }.training-arrow { color:#70a17f; font-size:44rpx; }
.quick-stages { margin-top: 16rpx; }

@keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-10rpx); } }
@keyframes sway { from { transform: rotate(-4deg); } to { transform: rotate(8deg); } }
