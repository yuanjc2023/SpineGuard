.container {
  display: block;
  width: 100%;
  box-sizing: border-box;
  min-height: 100vh;
  background: #f8f9fc;
  padding: 30rpx;
}

.section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 28rpx;
}

.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1A202C;
  margin-bottom: 24rpx;
}

.faq-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #EDF2F7;
}

.faq-item:last-child {
  border-bottom: 0;
}

.faq-question {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  font-size: 30rpx;
  color: #2D3748;
}

.arrow {
  color: #2ECC71;
  font-size: 24rpx;
}

.faq-answer {
  display: block;
  margin-top: 16rpx;
  color: #718096;
  font-size: 28rpx;
  line-height: 1.6;
}

.textarea,
.input {
  width: 100%;
  box-sizing: border-box;
  background: #F7FAFC;
  border-radius: 16rpx;
  color: #1A202C;
  font-size: 28rpx;
  padding: 22rpx;
  margin-bottom: 22rpx;
}

.textarea {
  min-height: 200rpx;
}

.input {
  height: 88rpx;
}

.submit-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: #2ECC71;
  color: #ffffff;
  font-size: 30rpx;
}
