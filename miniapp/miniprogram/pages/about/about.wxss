.container {
  display: block;
  width: 100%;
  box-sizing: border-box;
  min-height: 100vh;
  background: #f8f9fc;
  padding: 40rpx 30rpx;
}

.brand-card,
.info-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 28rpx;
}

.brand-card {
  text-align: center;
}

.brand-mark {
  width: 150rpx;
  height: 150rpx;
  line-height: 150rpx;
  text-align: center;
  border-radius: 50%;
  background: #E8F8EF;
  color: #2ECC71;
  font-size: 68rpx;
  font-weight: 700;
  margin-left: auto;
  margin-right: auto;
  margin-bottom: 18rpx;
}

.name,
.version,
.desc,
.copyright {
  display: block;
}

.name {
  font-size: 44rpx;
  font-weight: 700;
  color: #22543D;
}

.version {
  color: #718096;
  font-size: 26rpx;
  margin: 10rpx 0 22rpx;
}

.desc {
  color: #4A5568;
  font-size: 28rpx;
  line-height: 1.6;
}

.team-card {
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #E4F2E9;
  border-radius: 24rpx;
  padding: 34rpx 36rpx 10rpx;
  box-shadow: 0 10rpx 30rpx rgba(34, 84, 61, 0.05);
}

.team-heading {
  margin-bottom: 16rpx;
}

.team-title,
.team-subtitle,
.member-name,
.member-role {
  display: block;
}

.team-title {
  color: #22543D;
  font-size: 34rpx;
  font-weight: 700;
}

.team-subtitle {
  color: #94A69C;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.member-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #EDF2F7;
}

.member-row:last-child {
  border-bottom: 0;
}

.member-avatar {
  flex: none;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #E8F8EF;
  color: #27AE60;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 76rpx;
  text-align: center;
}

.member-info {
  min-width: 0;
  margin-left: 24rpx;
}

.member-name {
  color: #2D3748;
  font-size: 29rpx;
  font-weight: 600;
}

.member-role {
  color: #718096;
  font-size: 25rpx;
  margin-top: 7rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #EDF2F7;
  font-size: 28rpx;
  color: #2D3748;
}

.info-row:last-child {
  border-bottom: 0;
}

.link,
.value {
  color: #2ECC71;
  text-align: right;
  max-width: 420rpx;
}

.copyright {
  text-align: center;
  color: #A0AEC0;
  font-size: 24rpx;
  margin-top: 44rpx;
}
