page { background:#f4f7f5; color:#23352b; }
.container { width:100%; min-height:100vh; box-sizing:border-box; align-items:stretch; padding:24rpx 22rpx calc(46rpx + env(safe-area-inset-bottom)); }
.message { margin-bottom:18rpx; padding:18rpx 22rpx; border-radius:18rpx; font-size:25rpx; line-height:1.5; }.message.error { color:#9e3b3b; background:#fff0f0; }.message.warning { color:#8b6b34; background:#fff8e8; }
.loading-card { display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:270rpx; border-radius:26rpx; color:#87958d; background:#fff; font-size:21rpx; }.loading-dot { width:22rpx; height:22rpx; margin-bottom:14rpx; border:5rpx solid #dceee2; border-top-color:#35ad68; border-radius:50%; animation:spin .8s linear infinite; }.loading-dot.small { width:16rpx; height:16rpx; margin:0; border-width:4rpx; }
.detail-card { padding:28rpx; border-radius:29rpx; background:#fff; box-shadow:0 10rpx 30rpx rgba(38,72,52,.07); }.detail-head { display:flex; align-items:flex-start; justify-content:space-between; gap:18rpx; padding-bottom:23rpx; border-bottom:1rpx solid #edf1ee; }.head-copy { min-width:0; }.detail-kicker,.detail-title { display:block; }.detail-kicker { color:#3d9360; font-size:20rpx; font-weight:650; }.detail-title { margin:8rpx 0; color:#213328; font-size:31rpx; font-weight:800; }.detail-meta { display:flex; align-items:center; gap:10rpx; color:#99a39d; font-size:18rpx; }.read-state { padding:4rpx 10rpx; border-radius:99rpx; color:#4d8460; background:#ebf7ef; }
.risk-pill { flex-shrink:0; padding:8rpx 14rpx; border-radius:99rpx; color:#537669; background:#eaf4f0; font-size:19rpx; font-weight:650; }.risk-pill.low { color:#268653; background:#e8f8ee; }.risk-pill.medium { color:#a36c19; background:#fff6e3; }.risk-pill.high { color:#c43e3e; background:#fff0f0; }
.syncing-tip { display:flex; align-items:center; gap:12rpx; margin-top:18rpx; padding:14rpx 18rpx; border-radius:16rpx; color:#4c785c; background:#eef9f1; font-size:19rpx; }.fallback-notice { margin-top:18rpx; padding:17rpx 19rpx; border-radius:17rpx; color:#8a6830; background:#fff8e7; font-size:20rpx; line-height:1.55; }
.section-label { margin:18rpx 2rpx 9rpx; color:#31473a; font-size:25rpx; font-weight:800; }
.overview-grid { display:grid; grid-template-columns:1fr 1fr; grid-auto-rows:122rpx; gap:10rpx; }
.overview { display:flex; flex-direction:column; justify-content:center; min-width:0; min-height:0; padding:13rpx 18rpx; box-sizing:border-box; border:1rpx solid #edf1ee; border-radius:18rpx; background:#f6f8f7; }
.overview.primary { color:#fff; border-color:transparent; background:linear-gradient(145deg,#238a55,#43b970); box-shadow:0 8rpx 20rpx rgba(35,138,85,.13); }
.overview-label,.overview-value,.overview-sub { display:block; }
.overview-label { min-height:24rpx; color:#7f8e85; font-size:18rpx; line-height:1.3; }
.overview.primary .overview-label,.overview.primary .overview-sub { color:rgba(255,255,255,.78); }
.overview-value { margin-top:4rpx; font-size:38rpx; font-weight:850; line-height:1.05; }
.overview-value.small { color:#2e4136; font-size:27rpx; }
.overview-sub { margin-top:4rpx; font-size:17rpx; }
.detail-section { margin-top:22rpx; padding:22rpx; border-radius:21rpx; background:#f7f9f8; }.detail-section-head,.trend-head,.advice-head { display:flex; align-items:flex-start; justify-content:space-between; gap:15rpx; }.detail-section-title,.detail-section-sub { display:block; }.detail-section-title { color:#273a2f; font-size:26rpx; font-weight:750; }.detail-section-sub { margin-top:4rpx; color:#9aa59e; font-size:17rpx; }.pai-label,.generated-tag { flex-shrink:0; padding:6rpx 11rpx; border-radius:99rpx; color:#547465; background:#e8f1ec; font-size:17rpx; }
.posture-stack { display:flex; width:100%; height:18rpx; margin-top:18rpx; overflow:hidden; border-radius:99rpx; background:#e7ece9; }
.posture-stack-segment { height:100%; min-width:0; }
.posture-compact-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:10rpx; margin-top:14rpx; }
.posture-compact-item { min-width:0; padding:10rpx 11rpx; border-radius:14rpx; background:#fff; }
.posture-compact-head { display:flex; align-items:center; min-width:0; gap:6rpx; color:#66756c; font-size:17rpx; line-height:1.3; }
.posture-dot { width:11rpx; height:11rpx; flex-shrink:0; border-radius:50%; }
.posture-name { min-width:0; overflow:hidden; white-space:nowrap; text-overflow:ellipsis; }
.posture-percent { margin-left:auto; flex-shrink:0; color:#34483c; font-weight:750; }
.posture-duration { display:block; margin:5rpx 0 0 17rpx; overflow:hidden; color:#91a097; font-size:17rpx; line-height:1.3; white-space:nowrap; text-overflow:ellipsis; }
.posture-normal { background:#42c98b; }
.posture-left_lean { background:#66a9ef; }
.posture-right_lean { background:#f3c45d; }
.posture-front_lean { background:#ff9369; }
.posture-back_lean { background:#a98bdd; }
.posture-poor { background:#ee8068; }
.trend-card { border:1rpx solid #e2ece5; }.trend-card.improving { background:#effaf3; }.trend-card.worsening { background:#fff5f0; }.trend-card.stable,.trend-card.insufficient { background:#f6f8f7; }.trend-pill { padding:6rpx 12rpx; border-radius:99rpx; color:#47795a; background:rgba(255,255,255,.8); font-size:18rpx; font-weight:700; }.trend-card.worsening .trend-pill { color:#b4553d; }.trend-copy { display:block; margin-top:13rpx; color:#5f7066; font-size:21rpx; line-height:1.55; }.trend-compare { display:flex; justify-content:space-between; gap:10rpx; margin-top:15rpx; color:#86948c; font-size:18rpx; }
.compact-section { padding-top:10rpx; padding-bottom:10rpx; }.fact-row { display:flex; justify-content:space-between; gap:25rpx; padding:14rpx 0; border-bottom:1rpx solid #e8edea; color:#69776f; font-size:20rpx; }.fact-row:last-child { border-bottom:0; }.fact-row text:last-child { color:#34463c; font-weight:650; text-align:right; }.fact-row.data-range text:last-child { max-width:70%; font-size:18rpx; line-height:1.45; }.advice-section { background:#eff8f3; }.advice-rich { display:block; margin-top:17rpx; }.report-actions { display:grid; grid-template-columns:1fr 1fr; gap:12rpx; margin-top:22rpx; padding-top:18rpx; border-top:1rpx solid #dcebe1; }.report-action { display:flex; align-items:center; justify-content:center; min-width:0; height:70rpx; margin:0; padding:0 12rpx; border-radius:18rpx; font-size:21rpx; font-weight:700; line-height:1; }.report-action.secondary { color:#27764c; background:#fff; box-shadow:inset 0 0 0 1rpx #5dca83; }.report-action.primary { color:#fff; background:linear-gradient(135deg,#238a55,#3eb76e); box-shadow:0 7rpx 16rpx rgba(23, 1, 12, 0.16); }.report-action.primary[disabled] { color:#24342a; background:#1ac95d; box-shadow:none; }.action-icon { margin-right:7rpx; font-size:25rpx; }.medical-note { display:block; margin:20rpx 8rpx 2rpx; color:#9aa59e; font-size:18rpx; line-height:1.55; text-align:center; }.export-canvas { position:fixed; left:-10000px; top:0; width:1px; height:1px; opacity:.01; pointer-events:none; }
@keyframes spin { to { transform:rotate(360deg); } }
